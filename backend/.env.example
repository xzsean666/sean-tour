PORT=3000
NODE_ENV=development
# Optional. In development, leave empty to allow local cross-origin frontend access.
# In production, set explicit origins if the frontend is hosted separately.
CORS_ORIGIN=http://localhost:5173
# Optional GraphQL devtools toggles. Defaults are enabled in development and disabled in production.
GRAPHQL_PLAYGROUND_ENABLED=true
GRAPHQL_INTROSPECTION_ENABLED=true

PROJECT_NAME=sean-tour-backend
PUBLIC_IP=

JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=604800
# Optional server-to-server fallback for callback/sync/manual tools.
# `pnpm --dir backend deploy:payment-test-kit` can auto-generate one for test envs.
ADMIN_AUTH_CODE=
# Browser admin access is resolved on the backend from logged-in users.
ADMIN_USER_IDS=
ADMIN_USER_EMAILS=
USER_DATA_SECRET=replace-with-profile-data-secret

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

WECHAT_APP_ID=
WECHAT_APP_SECRET=

DATABASE_URL=
DATABASE_PREFIX=sean_tour

# Required for /payment/callback/usdt HMAC signature verification.
# `pnpm --dir backend deploy:payment-test-kit` can reuse or auto-generate one for test envs.
PAYMENT_CALLBACK_SECRET=replace-with-payment-callback-secret
PAYMENT_REPLAY_COOLDOWN_SECONDS=90
# Can be auto-populated by `pnpm --dir backend deploy:payment-test-kit`.
PAYMENT_BSC_RPC_URL=
PAYMENT_BSC_CHAIN_ID=56
PAYMENT_USDT_BSC_TOKEN_ADDRESS=
PAYMENT_BATCH_CALL_ADDRESS=
PAYMENT_MASTER_PRIVATE_KEY=
PAYMENT_ORDER_EXPIRY_HOURS=0.5
PAYMENT_TOKEN_DECIMALS=18

GRAYLOG_HOST=
GRAYLOG_PORT=12201

ALERT_HOST_NAME=
SLACK_WEBHOOK_URL=
DING_WEBHOOK_URL=
DING_WEBHOOK_SECRET=
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
ALERT_RULES=[{"minLevel":1,"repeatCount":1,"repeatIntervalSeconds":60}]
